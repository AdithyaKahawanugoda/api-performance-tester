{
  "name": "@api-perf/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx --env-file .env --watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
