    "ioredis": "^5.4.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "undici": "^8.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2"
  }
}
